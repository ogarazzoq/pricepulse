# Server
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pricepulse?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-another-strong-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Mailer (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=PricePulse <noreply@pricepulse.io>

# Telegram
TELEGRAM_BOT_TOKEN=8938611469:AAHXb9K4NVTkLIjfC9zL9opUuGsvcuqbnDA

# Marketplace integrations
BESTBUY_API_KEY=
UPCITEMDB_API_KEY=

# RapidAPI (for Amazon and other premium APIs)
RAPIDAPI_KEY=
AMAZON_COUNTRY=US

# Olcha.uz
OLCHA_API_URL=https://api.olcha.uz/api/v1

# Jobs
PRICE_SYNC_CRON=0 */2 * * *
ALERT_EVALUATE_CRON=*/15 * * * *

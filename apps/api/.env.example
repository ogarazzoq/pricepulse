# Server
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pricepulse?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-another-strong-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Mailer (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=PricePulse <noreply@pricepulse.io>

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_MODE=polling
# TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/v1/telegram/webhook

# Admin bootstrap (optional — creates admin user on boot)
BOOTSTRAP_ADMIN_EMAIL=admin@yourcompany.com
BOOTSTRAP_ADMIN_PASSWORD=SecurePassword123
BOOTSTRAP_ADMIN_NAME=Admin

# Super-admin (optional — always kept as ADMIN role, useful for your own account)
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=

# Marketplace integrations
BESTBUY_API_KEY=
UPCITEMDB_API_KEY=

# RapidAPI (for Amazon and other premium APIs)
RAPIDAPI_KEY=
AMAZON_COUNTRY=US

# Olcha.uz
OLCHA_API_URL=https://api.olcha.uz/api/v1

# Jobs
PRICE_SYNC_CRON=0 */2 * * *
ALERT_EVALUATE_CRON=*/15 * * * *

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Price Drop Alert</title>
    <!--[if mso]>
    <noscript>
        <xml>
            <o:OfficeDocumentSettings>
                <o:PixelsPerInch>96</o:PixelsPerInch>
            </o:OfficeDocumentSettings>
        </xml>
    </noscript>
    <![endif]-->
    <style>
        /* Reset styles */
        body {
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            line-height: 1.6;
            color: #1f2937;
            background-color: #f3f4f6;
        }
        
        table {
            border-collapse: collapse;
            width: 100%;
        }
        
        img {
            max-width: 100%;
            height: auto;
            display: block;
        }
        
        /* Container */
        .container {
            max-width: 600px;
            margin: 0 auto;
            background-color: #ffffff;
        }
        
        /* Header */
        .header {
            background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
            padding: 32px 24px;
            text-align: center;
        }
        
        .header-title {
            color: #ffffff;
            font-size: 24px;
            font-weight: 700;
            margin: 0;
        }
        
        /* Content */
        .content {
            padding: 32px 24px;
        }
        
        .alert-badge {
            display: inline-block;
            background-color: #10b981;
            color: #ffffff;
            padding: 8px 16px;
            border-radius: 9999px;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 16px;
        }
        
        .product-section {
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 20px;
            margin: 24px 0;
            background-color: #f9fafb;
        }
        
        .product-image-container {
            text-align: center;
            margin-bottom: 20px;
        }
        
        .product-image {
            max-width: 200px;
            height: auto;
            border-radius: 8px;
            margin: 0 auto;
        }
        
        .product-title {
            font-size: 20px;
            font-weight: 600;
            color: #111827;
            margin: 0 0 16px 0;
            line-height: 1.4;
        }
        
        .price-comparison {
            background-color: #ffffff;
            border-radius: 8px;
            padding: 20px;
            margin-top: 16px;
        }
        
        .price-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
        }
        
        .price-label {
            font-size: 14px;
            color: #6b7280;
            font-weight: 500;
        }
        
        .price-value {
            font-size: 18px;
            font-weight: 700;
            font-family: 'Courier New', monospace;
        }
        
        .old-price {
            color: #ef4444;
            text-decoration: line-through;
        }
        
        .new-price {
            color: #10b981;
        }
        
        .savings {
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            color: #ffffff;
            padding: 16px;
            border-radius: 8px;
            text-align: center;
            margin-top: 16px;
        }
        
        .savings-amount {
            font-size: 28px;
            font-weight: 700;
            font-family: 'Courier New', monospace;
            display: block;
        }
        
        .savings-percent {
            font-size: 16px;
            opacity: 0.9;
            margin-top: 4px;
        }
        
        .marketplace-info {
            color: #6b7280;
            font-size: 14px;
            margin-top: 12px;
            padding: 12px;
            background-color: #f3f4f6;
            border-radius: 6px;
        }
        
        .marketplace-name {
            font-weight: 600;
            color: #111827;
        }
        
        /* CTA Button */
        .cta-container {
            text-align: center;
            margin: 32px 0;
        }
        
        .cta-button {
            display: inline-block;
            background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
            color: #ffffff;
            text-decoration: none;
            padding: 16px 32px;
            border-radius: 8px;
            font-weight: 600;
            font-size: 16px;
            transition: transform 0.2s;
        }
        
        .cta-button:hover {
            transform: translateY(-2px);
        }
        
        /* Footer */
        .footer {
            background-color: #f9fafb;
            padding: 24px;
            text-align: center;
            color: #6b7280;
            font-size: 12px;
            line-height: 1.5;
        }
        
        .footer a {
            color: #6366f1;
            text-decoration: none;
        }
        
        /* Responsive */
        @media only screen and (max-width: 600px) {
            .header-title {
                font-size: 20px;
            }
            
            .product-title {
                font-size: 18px;
            }
            
            .savings-amount {
                font-size: 24px;
            }
            
            .content {
                padding: 24px 16px;
            }
        }
    </style>
</head>
<body>
    <table role="presentation" cellspacing="0" cellpadding="0" style="width: 100%; background-color: #f3f4f6;">
        <tr>
            <td style="padding: 20px 0;">
                <div class="container">
                    <!-- Header -->
                    <div class="header">
                        <h1 class="header-title">🔔 Price Drop Alert!</h1>
                    </div>
                    
                    <!-- Content -->
                    <div class="content">
                        <div style="text-align: center;">
                            <span class="alert-badge">💰 Great news!</span>
                        </div>
                        
                        <p style="font-size: 16px; color: #374151; margin: 16px 0 0 0;">
                            A product you're watching has dropped in price:
                        </p>
                        
                        <!-- Product Section -->
                        <div class="product-section">
                            {{#if productImage}}
                            <div class="product-image-container">
                                <img src="{{productImage}}" alt="{{productTitle}}" class="product-image">
                            </div>
                            {{/if}}
                            
                            <h2 class="product-title">{{productTitle}}</h2>
                            
                            <!-- Price Comparison -->
                            <div class="price-comparison">
                                <table role="presentation" cellspacing="0" cellpadding="0" style="width: 100%;">
                                    <tr>
                                        <td class="price-label">Old Price:</td>
                                        <td class="price-value old-price" style="text-align: right;">{{oldPrice}}</td>
                                    </tr>
                                    <tr>
                                        <td class="price-label">New Price:</td>
                                        <td class="price-value new-price" style="text-align: right;">{{newPrice}}</td>
                                    </tr>
                                </table>
                                
                                <!-- Savings Box -->
                                <div class="savings">
                                    <span class="savings-amount">You save {{savingsAmount}}</span>
                                    <div class="savings-percent">That's {{savingsPercent}}% off!</div>
                                </div>
                            </div>
                            
                            <!-- Marketplace Info -->
                            <div class="marketplace-info">
                                Available on <span class="marketplace-name">{{marketplaceName}}</span>
                            </div>
                        </div>
                        
                        <!-- CTA -->
                        <div class="cta-container">
                            <a href="{{productUrl}}" class="cta-button" target="_blank">
                                View Product →
                            </a>
                        </div>
                        
                        <p style="font-size: 14px; color: #6b7280; text-align: center; margin-top: 24px;">
                            This price was detected {{condition}} your threshold of <strong>{{threshold}}</strong>
                        </p>
                    </div>
                    
                    <!-- Footer -->
                    <div class="footer">
                        <p style="margin: 0 0 8px 0;">
                            <strong>PricePulse</strong> — Your smart price tracking companion
                        </p>
                        <p style="margin: 0 0 8px 0;">
                            Manage your alerts at <a href="{{appUrl}}/alerts">{{appUrl}}/alerts</a>
                        </p>
                        <p style="margin: 8px 0 0 0; color: #9ca3af;">
                            You're receiving this because you set up a price alert.<br>
                            To stop receiving these emails, pause or delete the alert in your dashboard.
                        </p>
                    </div>
                </div>
            </td>
        </tr>
    </table>
</body>
</html>
